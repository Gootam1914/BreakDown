datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id    String   @id 
  name  String
  time  DateTime @default(now())
  logs  Log[]
  items Item[]
}

model Log {
  id    String   @id @default(uuid())
  title String     
  uid   String
  user  User     @relation(fields: [uid], references: [id], onDelete: Cascade)
  time  DateTime @default(now())
  items Item[]
}

model Item {
  id    String   @id @default(uuid())
  lid   String
  log   Log      @relation(fields: [lid], references: [id], onDelete: Cascade)
  uid   String
  user  User     @relation(fields: [uid], references: [id], onDelete: Cascade)
  title String
  info  String   @db.Text
  mode  String   @default("General")
  rate  Float    @default(0.0)
  meta  Json         
  steps Step[]
  time  DateTime @default(now())
}

model Step {
  id    String   @id @default(uuid())
  iid   String
  item  Item     @relation(fields: [iid], references: [id], onDelete: Cascade)
  title String
  days  Int      @default(1)
  diff  String   @default("Medium") 
  state String   @default("Pending") 
  time  DateTime @default(now())
}