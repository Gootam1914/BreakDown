datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// 1. Unified Identity Record for Both Guest and Google Sessions
model User {
  id            String         @id // Matches 'goog_usr_*' or 'local_usr_*'
  name          String
  createdAt     DateTime       @default(now())
  conversations Conversation[]
  blueprints    Blueprint[]
}

// 2. Chat History Tracking (Feeds the User-Isolated Sidebar Left Panel)
model Conversation {
  id         String     @id @default(uuid())
  title      String     // Stores the project title generated by Gemini
  userId     String
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime   @default(now())
  blueprints Blueprint[]
}

// 3. Compiled Strategy Matrix
model Blueprint {
  id             String       @id @default(uuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  title          String
  description    String       @db.Text
  mode           String       @default("General")
  score          Float        @default(0.0)
  metrics        Json         // Stores dynamic breakdowns like feasibility metrics
  tasks          Task[]
  createdAt      DateTime     @default(now())
}

// 4. Sequential Decomposed Actionable Objectives
model Task {
  id           String    @id @default(uuid())
  blueprintId  String
  blueprint    Blueprint @relation(fields: [blueprintId], references: [id], onDelete: Cascade)
  title        String
  durationDays Int       @default(1)
  complexity   String    @default("Medium") // Low, Medium, High
  status       String    @default("Pending") // Pending, Active, Completed
  createdAt    DateTime  @default(now())
}